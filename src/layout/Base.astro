---
import { enableSubscribeJS, nextShip } from '../resource/variables.js';
const defaultTitle = 'Dear Nervous System | Monthly Mail Club in Dubai';
const defaultDescription = 'A monthly envelope of calm delivered to your door in Dubai. Personal letters, regulation cards, and healing practice highlights. AED 55/month. Cancel anytime.';

const {
  title = defaultTitle,
  description = defaultDescription,
  ogType = 'website',
} = Astro.props;

const siteOrigin = (Astro.site?.toString() ?? 'https://dearnervoussystem.shop/').replace(/\/$/, '');
const canonicalUrl = new URL(Astro.url.pathname, `${siteOrigin}/`).toString();
const socialImage = `${siteOrigin}/favicon.svg`;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Dear Nervous System',
  url: siteOrigin,
  inLanguage: 'en-AE',
  description,
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Dear Nervous System',
  url: siteOrigin,
  email: 'dearnervoussystemmail@gmail.com',
  areaServed: 'Dubai, UAE',
};
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1">
<meta name="theme-color" content="#f5ebe0">

<link rel="canonical" href={canonicalUrl}>
<link rel="alternate" href={canonicalUrl} hreflang="en-ae">

<meta property="og:type" content={ogType}>
<meta property="og:site_name" content="Dear Nervous System">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:url" content={canonicalUrl}>
<meta property="og:image" content={socialImage}>
<meta property="og:locale" content="en_AE">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={socialImage}>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Jost:ital,wght@0,300;0,400;0,500;1,300&family=Petit+Formal+Script&display=swap" rel="stylesheet">
<link rel="stylesheet" href="assets/css/main.css">
<link rel="icon" type="image/svg+xml" href="favicon.svg">

<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
<script async src="https://www.googletagmanager.com/gtag/js?id=G-6D9RDGLQR5"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-6D9RDGLQR5');
</script>
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-TVMG7QX6');</script>

</head>
<body>
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TVMG7QX6"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<div class="ann">✦ Next batch ships <strong>{nextShip}</strong> · Dubai delivery included · <strong>30 spots</strong> remaining this month</div>

<nav>
  <a href="#" class="logo">Dear Nervous System</a>
  <div class="nav-links">
    <a href="#inside" class="nav-a">What's inside</a>
    <a href="#letter" class="nav-a">The letter</a>
    <a href="#faq" class="nav-a">FAQ</a>
    {enableSubscribeJS && <a href="https://buy.stripe.com/bJe6oAaXcbew3KDcDD6kg03" class="nav-a nav-btn">Subscribe — AED 55</a>}
  </div>
</nav>

<slot />

<!-- FOOTER -->
<footer>
  <a href="#" class="footer-logo">Dear Nervous System</a>
  <div class="footer-links">
    {enableSubscribeJS && <a href="https://buy.stripe.com/bJe6oAaXcbew3KDcDD6kg03">Subscribe</a>}
    <a href="#faq">FAQ</a>
    <a href="mailto:dns@dearnervoussystem.shop">Contact</a>
  </div>
  <div class="footer-r">
    Monthly Mail Club · Dubai, UAE<br>
    dearnervoussystem.shop
  </div>
</footer>

{enableSubscribeJS && <script is:inline src="assets/js/subscribe.js"></script>}
<script is:inline src="assets/js/main.js"></script>
</body>
</html>
